# Placeholder-only example values. Do not copy production secrets, customer data, tenant fixtures, exports, or live integration credentials into this file.
# Set LOCAL_SERVICES=yes, LOCAL_DB=yes, LOCAL_DESTRUCTIVE=yes, LOCAL_CUSTOMER_DATA_OPS=yes, or LOCAL_PRODUCTION_OPS=yes only for explicit local operations.

# =============================================================================
# COFORMA STUDIO - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string (Railway managed)
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://coforma:password@localhost:5432/coforma_dev?schema=public"

# Database connection pool size
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================================================
# REDIS
# =============================================================================

# Redis connection string (Railway managed)
# Format: redis://user:password@host:port
REDIS_URL="redis://localhost:6379"

# Redis connection pool
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# =============================================================================
# MEILISEARCH
# =============================================================================

# Meilisearch host and master key
MEILISEARCH_HOST="https://example.invalid"
MEILISEARCH_MASTER_KEY="change-me-placeholder"

# =============================================================================
# AUTHENTICATION (NextAuth.js v5)
# =============================================================================

# NextAuth configuration
NEXTAUTH_URL="https://example.invalid"
NEXTAUTH_SECRET="change-me-placeholder"

# OAuth Providers (optional - configure as needed)
GOOGLE_CLIENT_ID="change-me-placeholder"
GOOGLE_CLIENT_SECRET="change-me-placeholder"

MICROSOFT_CLIENT_ID="change-me-placeholder"
MICROSOFT_CLIENT_SECRET="change-me-placeholder"

# Generic OIDC provider (for custom SSO)
OIDC_CLIENT_ID="change-me-placeholder"
OIDC_CLIENT_SECRET="change-me-placeholder"
OIDC_ISSUER="placeholder-value"

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL="http://localhost:4000"

# tRPC endpoint
NEXT_PUBLIC_TRPC_URL="http://localhost:4000/trpc"

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CLOUDFLARE (Storage & CDN)
# =============================================================================

# Cloudflare R2 (S3-compatible)
CLOUDFLARE_ACCOUNT_ID="placeholder-value"
CLOUDFLARE_ACCESS_KEY_ID="change-me-placeholder"
CLOUDFLARE_SECRET_ACCESS_KEY="change-me-placeholder"

# R2 Bucket names
R2_BUCKET_UPLOADS="placeholder-value"
R2_BUCKET_EXPORTS="placeholder-value"
R2_BUCKET_PUBLIC="placeholder-value"

# Cloudflare CDN
CLOUDFLARE_CDN_URL="https://example.invalid"

# Cloudflare Turnstile (CAPTCHA alternative)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="change-me-placeholder"
TURNSTILE_SECRET_KEY="change-me-placeholder"

# =============================================================================
# STRIPE (Payments & Billing)
# =============================================================================

# Stripe API keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY="change-me-placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="change-me-placeholder"

# Stripe webhook secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET="change-me-placeholder"

# Stripe product/price IDs (configure after creating in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER="placeholder-value"
STRIPE_PRICE_ID_PROFESSIONAL="placeholder-value"
STRIPE_PRICE_ID_ENTERPRISE="placeholder-value"

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY="change-me-placeholder"

# Sender email (must be verified in Resend)
EMAIL_FROM="Coforma Studio <noreply@coforma.studio>"

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Zoom
ZOOM_CLIENT_ID="change-me-placeholder"
ZOOM_CLIENT_SECRET="change-me-placeholder"
ZOOM_WEBHOOK_SECRET="change-me-placeholder"

# Slack
SLACK_CLIENT_ID="change-me-placeholder"
SLACK_CLIENT_SECRET="change-me-placeholder"
SLACK_SIGNING_SECRET="change-me-placeholder"

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID="change-me-placeholder"
GOOGLE_CALENDAR_CLIENT_SECRET="change-me-placeholder"

# Jira
JIRA_CLIENT_ID="change-me-placeholder"
JIRA_CLIENT_SECRET="change-me-placeholder"
JIRA_WEBHOOK_SECRET="change-me-placeholder"

# Asana
ASANA_CLIENT_ID="change-me-placeholder"
ASANA_CLIENT_SECRET="change-me-placeholder"

# ClickUp
CLICKUP_CLIENT_ID="change-me-placeholder"
CLICKUP_CLIENT_SECRET="change-me-placeholder"

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN="change-me-placeholder"
SENTRY_ORG="placeholder-value"
SENTRY_PROJECT="placeholder-value"

# Better Stack / Logtail (Logging)
LOGTAIL_SOURCE_TOKEN="change-me-placeholder"

# PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY="change-me-placeholder"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# SECURITY
# =============================================================================

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="change-me-placeholder"

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://coforma.studio,https://*.coforma.studio"

# Content Security Policy nonce (auto-generated if not set)
CSP_NONCE=""

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable features per environment
FEATURE_FLAG_GOOGLE_CALENDAR=placeholder-value
FEATURE_FLAG_ZOOM_INTEGRATION=placeholder-value
FEATURE_FLAG_JIRA_SYNC=placeholder-value
FEATURE_FLAG_ASANA_SYNC=placeholder-value
FEATURE_FLAG_CLICKUP_SYNC=placeholder-value
FEATURE_FLAG_WHITE_LABEL=false
FEATURE_FLAG_SSO_SAML=false

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Environment name (development, staging, production)
NODE_ENV="development"
NEXT_PUBLIC_ENV="development"

# Application URL (for email links, etc.)
APP_URL="http://localhost:3000"

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Prisma Studio (database GUI)
# Access at: http://localhost:5555
# Run with: pnpm db:studio

# Seed database on startup (development only)
SEED_DATABASE=false

# Debug logging
DEBUG=false
LOG_LEVEL="info"  # error, warn, info, debug, trace
LOCAL_SERVICES=no
LOCAL_DB=no
LOCAL_DESTRUCTIVE=no
LOCAL_CUSTOMER_DATA_OPS=no
LOCAL_PRODUCTION_OPS=no
